/* pages/device-detail/device-detail.wxss */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
}

.device-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.device-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.device-status {
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.device-status.normal {
  background-color: #e6f7ff;
  color: #1890ff;
}

.device-status.fault {
  background-color: #fff2e8;
  color: #fa541c;
}

.device-info {
  background-color: #ffffff;
  border-radius: 10rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.info-item {
  display: flex;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  width: 180rpx;
  color: #666666;
  font-size: 28rpx;
}

.value {
  flex: 1;
  color: #333333;
  font-size: 28rpx;
  word-break: break-all;
}

.section {
  background-color: #ffffff;
  border-radius: 10rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.parameter-list {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  box-sizing: border-box;
}

.parameter-item {
  width: 50%;
  padding: 15rpx 0;
  box-sizing: border-box;
}

.param-name {
  font-size: 26rpx;
  color: #666666;
  margin-right: 10rpx;
}

.param-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.repair-list {
  padding: 10rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.empty-tip {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
  padding: 40rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.repair-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.repair-item:last-child {
  border-bottom: none;
}

.repair-time {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.repair-desc {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
  word-break: break-all;
}

.repair-person {
  font-size: 24rpx;
  color: #666666;
}

.action-bar {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.action-btn {
  width: 48%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.action-btn.report {
  background-color: #ff4d4f;
  color: #ffffff;
}

.action-btn.maintenance {
  background-color: #0078D7;
  color: #ffffff;
} 