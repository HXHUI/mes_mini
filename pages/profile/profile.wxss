/* pages/profile/profile.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
}

/* 用户卡片 */
.user-card {
  width: 100%;
  background-color: #0078D7;
  padding: 40rpx 30rpx;
  color: #ffffff;
  box-sizing: border-box;
}

.user-info {
  display: flex;
  align-items: center;
  width: 100%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #ffffff;
  margin-right: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.user-meta {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 菜单列表 */
.menu-list {
  width: 100%;
  margin-top: 20rpx;
  background-color: #ffffff;
  overflow: hidden;
  box-sizing: border-box;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-box {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #0078D7;
  background-color: rgba(0, 120, 215, 0.1);
  border-radius: 8rpx;
}

.menu-icon.repair {
  background-color: rgba(0, 120, 215, 0.1);
  color: #0078D7;
}

.menu-icon.history {
  background-color: rgba(0, 120, 215, 0.1);
  color: #0078D7;
}

.menu-icon.star {
  background-color: rgba(0, 120, 215, 0.1);
  color: #0078D7;
}

.menu-icon.setting {
  background-color: rgba(0, 120, 215, 0.1);
  color: #0078D7;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #cccccc;
  border-right: 2rpx solid #cccccc;
  transform: rotate(45deg);
}

/* 底部区域 */
.footer {
  width: 100%;
  margin-top: 40rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  background-color: #ffffff;
  color: #ff4d4f;
  font-size: 32rpx;
  border: none;
}

.version {
  width: 100%;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 40rpx;
  padding-bottom: 30rpx;
} 