<!-- pages/account-bind/account-bind.wxml -->
<view class="container">
  <view class="logo-area">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <view class="title">账号绑定</view>
    <view class="subtitle">请绑定您的系统账号</view>
  </view>
  
  <view class="bind-form">
    <view class="input-group">
      <view class="input-label">用户名</view>
      <input class="input" type="text" placeholder="请输入用户名" bindinput="onUsernameInput" value="{{username}}"/>
    </view>
    
    <view class="input-group">
      <view class="input-label">密码</view>
      <input class="input" password placeholder="请输入密码" bindinput="onPasswordInput" value="{{password}}"/>
    </view>
    
    <button class="bind-btn" bindtap="handleBind" loading="{{isBinding}}" disabled="{{isBinding}}">
      {{isBinding ? '绑定中...' : '绑定账号'}}
    </button>
    
    <view class="tips">
      <text>绑定后可使用微信快捷登录</text>
    </view>
  </view>
  
  <view class="actions">
    <button class="back-btn" bindtap="handleBack">返回登录</button>
  </view>
</view> 