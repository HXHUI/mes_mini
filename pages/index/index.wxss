/* pages/index/index.wxss */
.container {
  padding: 0;
  background-color: #f7f8fa;
  min-height: 100vh;
  box-sizing: border-box;
  overflow: hidden;
  padding-bottom: 100rpx;
}

/* 顶部欢迎区 */
.header {
  background-color: #0078D7;
  padding: 40rpx 30rpx;
  color: #ffffff;
  margin-bottom: 0;
  width: 100%;
  box-sizing: border-box;
}

.greeting {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.welcome {
  display: flex;
  flex-direction: column;
}

.welcome text:first-child {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.welcome-text {
  font-size: 28rpx;
  opacity: 0.9;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #ffffff;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 统计区域 */
.statistics-section {
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.statistics-area {
  width: 100%;
  margin: 20rpx auto;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  position: relative;
}

.repair-stats {
  border-left: 6rpx solid #2196F3;
}

.maintenance-stats {
  border-left: 6rpx solid #9C27B0;
}

.stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.stat-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.stat-more {
  font-size: 24rpx;
  color: #0078D7;
}

.stat-cards {
  display: flex;
  justify-content: space-between;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 10rpx 5rpx;
}

/* 添加分隔线 */
.stat-card:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 1rpx;
  background-color: #eeeeee;
}

.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.repair-stats .stat-number {
  color: #2196F3;
}

.maintenance-stats .stat-number {
  color: #9C27B0;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

/* 功能卡片区 */
.function-area {
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background-color: #0078D7;
  border-radius: 3rpx;
}

.function-cards {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.function-card {
  width: 100%;
  height: 160rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #ffffff;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s ease;
  box-sizing: border-box;
}

.function-card:active {
  transform: scale(0.98);
}

/* 图标样式 */
.card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.15);
}

.card-image {
  width: 44rpx;
  height: 44rpx;
  filter: brightness(1.1);
}

.card-info {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 24rpx;
  opacity: 0.9;
} 