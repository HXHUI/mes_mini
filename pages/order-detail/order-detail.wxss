/* pages/order-detail/order-detail.wxss */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.order-id {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.order-status {
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.order-status.pending {
  background-color: #fff7e6;
  color: #fa8c16;
}

.order-status.processing {
  background-color: #e6f7ff;
  color: #1890ff;
}

.order-status.completed {
  background-color: #f6ffed;
  color: #52c41a;
}

.order-section {
  background-color: #ffffff;
  border-radius: 10rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  padding: 15rpx 0;
}

.info-item.description {
  display: block;
}

.info-item.description .label {
  display: block;
  margin-bottom: 10rpx;
}

.info-item.description .value {
  display: block;
  word-break: break-all;
  white-space: pre-wrap;
}

.label {
  width: 160rpx;
  color: #666666;
  font-size: 28rpx;
}

.value {
  flex: 1;
  color: #333333;
  font-size: 28rpx;
}

.value.urgency {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.value.urgency.high {
  background-color: #ffebeb;
  color: #ff4d4f;
}

.value.urgency.medium {
  background-color: #fff7e6;
  color: #fa8c16;
}

.value.urgency.low {
  background-color: #e6f7ff;
  color: #1890ff;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.fault-image {
  width: 200rpx;
  height: 200rpx;
  margin: 10rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
}

.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 0;
}

.action-btn {
  width: 320rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  background-color: #ffffff;
  color: #0078D7;
  border: 1rpx solid #0078D7;
}

.action-btn.handle {
  background-color: #0078D7;
  color: #ffffff;
  border: none;
}

.action-btn.complete {
  background-color: #52c41a;
  color: #ffffff;
  border: none;
}

.action-btn.view {
  background-color: #ffffff;
  color: #0078D7;
  border: 1rpx solid #0078D7;
} 