/* pages/messages/messages.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.message-list {
  padding: 0 0 20rpx 0;
}

.message-item {
  display: flex;
  padding: 30rpx;
  background-color: #ffffff;
  margin-bottom: 2rpx;
  position: relative;
  border-bottom: 1rpx solid #f0f0f0;
}

.message-item.unread {
  background-color: #f8f8ff;
}

.message-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #0078D7;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 40rpx;
}

.message-icon.repair::after {
  content: "修";
}

.message-icon.notice::after {
  content: "通";
}

.message-icon.approval::after {
  content: "批";
}

.unread-dot {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
}

.message-content {
  flex: 1;
  overflow: hidden;
}

.message-title {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.message-preview {
  font-size: 28rpx;
  color: #666666;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.message-time {
  font-size: 24rpx;
  color: #999999;
}

.message-arrow {
  display: flex;
  align-items: center;
  padding: 0 10rpx;
}

.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #cccccc;
  border-right: 2rpx solid #cccccc;
  transform: rotate(45deg);
}

.empty-list {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  background-color: #e0e0e0;
  border-radius: 50%;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
}

.loading-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #0078D7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666666;
}

.load-all {
  text-align: center;
  padding: 30rpx 0;
  color: #999999;
  font-size: 28rpx;
} 