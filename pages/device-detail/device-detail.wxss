/* pages/device-detail/device-detail.wxss */
.container {
  padding: 12rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
}

.content-wrapper {
  width: 100%;
  box-sizing: border-box;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300rpx;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #0078D7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #666;
  font-size: 28rpx;
}

/* 设备卡片 */
.device-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.device-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 2;
  width: 100%;
}

.device-title {
  flex: 1;
}

.device-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.device-id {
  font-size: 26rpx;
  color: #888888;
}

.device-status {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  height: 40rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.device-status.normal {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.device-status.normal .status-dot {
  background-color: #52c41a;
  box-shadow: 0 0 8rpx #52c41a;
}

.device-status.fault {
  background-color: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.device-status.fault .status-dot {
  background-color: #ff4d4f;
  box-shadow: 0 0 8rpx #ff4d4f;
}

/* 设备状态图标 */
.device-status-icon {
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  width: 200rpx;
  height: 200rpx;
  opacity: 0.1;
  z-index: 1;
}

.icon-circle {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.device-status-icon.normal .icon-circle {
  background-color: rgba(82, 196, 26, 0.2);
}

.device-status-icon.fault .icon-circle {
  background-color: rgba(255, 77, 79, 0.2);
}

.icon-inner {
  width: 60%;
  height: 60%;
  border-radius: 50%;
}

.device-status-icon.normal .icon-inner {
  background-color: rgba(82, 196, 26, 0.5);
}

.device-status-icon.fault .icon-inner {
  background-color: rgba(255, 77, 79, 0.5);
}

/* 信息卡片通用样式 */
.info-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
  width: 100%;
}

.title-line {
  width: 8rpx;
  height: 32rpx;
  background-color: #0078D7;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.card-title text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  flex: 1;
}

/* 刷新按钮样式 */
.refresh-btn {
  display: flex;
  align-items: center;
  padding: 6rpx 12rpx;
  border-radius: 30rpx;
  background-color: rgba(0, 120, 215, 0.1);
  color: #0078D7;
  font-size: 24rpx;
}

.refresh-btn:active {
  background-color: rgba(0, 120, 215, 0.2);
}

.refresh-icon {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid #0078D7;
  border-radius: 50%;
  position: relative;
  margin-right: 6rpx;
}

.refresh-icon::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  width: 8rpx;
  height: 8rpx;
  border-top: 2rpx solid #0078D7;
  border-right: 2rpx solid #0078D7;
  transform: translateX(-50%) rotate(-45deg);
}

.refresh-icon::after {
  content: '';
  position: absolute;
  bottom: 6rpx;
  left: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-bottom: 2rpx solid #0078D7;
  border-left: 2rpx solid #0078D7;
  transform: rotate(-45deg);
}

/* 记录类型筛选 */
.record-filter {
  display: flex;
  margin-bottom: 16rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
  padding: 6rpx 0;
}

.filter-item.active {
  color: #0078D7;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 4rpx;
  margin-right: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  position: relative;
}

.checkbox.checked {
  background-color: #0078D7;
  border-color: #0078D7;
}

.checkbox.checked::after {
  content: '';
  width: 16rpx;
  height: 8rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg);
  position: absolute;
  top: 8rpx;
}

.filter-item text {
  font-size: 26rpx;
  color: #666;
}

.filter-item.active text {
  color: #0078D7;
}

/* 信息网格布局 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-gap: 24rpx;
  width: 100%;
}

.info-item {
  display: flex;
  flex-direction: column;
  padding: 8rpx 0;
}

.label {
  color: #888888;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.value {
  color: #333333;
  font-size: 28rpx;
  font-weight: 500;
  word-break: break-all;
}

/* 设备描述 */
.info-desc {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  width: 100%;
}

.info-desc .label {
  margin-bottom: 12rpx;
}

.info-desc .value {
  font-weight: normal;
  line-height: 1.6;
}

/* 参数列表 */
.parameter-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-gap: 24rpx;
  width: 100%;
}

.parameter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  position: relative;
}

.parameter-item:active {
  background-color: #f0f0f0;
}

.param-content {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.param-name {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.param-value {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.param-unit {
  font-size: 24rpx;
  color: #888888;
  font-weight: normal;
  margin-left: 4rpx;
}

.param-history-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-icon {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid #0078D7;
  border-radius: 50%;
  position: relative;
}

.history-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 2rpx;
  background-color: #0078D7;
  transform: translate(-50%, -50%);
}

.history-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 2rpx;
  height: 10rpx;
  background-color: #0078D7;
  transform: translate(-50%, -50%);
}

.parameter-tip {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #888888;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.update-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999999;
}

/* 维修记录 */
.repair-list {
  padding: 8rpx 0;
  width: 100%;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 28rpx;
  width: 100%;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.repair-item {
  padding: 20rpx;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.repair-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  width: 100%;
}

.repair-time {
  font-size: 24rpx;
  color: #888888;
}

.repair-type {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.repair-type.repair-type {
  color: #ff4d4f;
  background-color: rgba(255, 77, 79, 0.1);
}

.repair-type.maintenance-type {
  color: #1890ff;
  background-color: rgba(24, 144, 255, 0.1);
}

.repair-desc {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.5;
  word-break: break-all;
}

.repair-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.repair-person {
  font-size: 24rpx;
  color: #666666;
  flex: 1;
}

.repair-status-tag {
  font-size: 22rpx;
  color: #52c41a;
  background-color: rgba(82, 196, 26, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.repair-more {
  font-size: 24rpx;
  color: #0078D7;
}

/* 无数据提示 */
.empty-data {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
} 