<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 顶部欢迎区 -->
  <view class="header">
    <view class="greeting">
      <view class="welcome">
        <text>Hi，{{userInfo.real_name || '用户'}}</text>
        <text class="welcome-text">欢迎使用MES生产执行管理系统</text>
      </view>
      <image class="avatar" src="{{userInfo.avatar || '/images/icons/avatar-default.png'}}" mode="aspectFill"></image>
    </view>
  </view>
  
  <!-- 统计区域 -->
  <view class="statistics-section">
    <view class="section-title">工单统计</view>
    
    <!-- 维修工单统计 -->
    <view class="statistics-area repair-stats" bindtap="viewRepairOrders">
      <view class="stat-header">
        <text class="stat-title">维修工单</text>
        <text class="stat-more">查看全部 ></text>
      </view>
      <view class="stat-cards">
        <view class="stat-card">
          <text class="stat-number">{{statistics.repair.todoCount || 0}}</text>
          <text class="stat-label">待执行</text>
        </view>
        <view class="stat-card">
          <text class="stat-number">{{statistics.repair.processingCount || 0}}</text>
          <text class="stat-label">执行中</text>
        </view>
        <view class="stat-card">
          <text class="stat-number">{{statistics.repair.completedCount || 0}}</text>
          <text class="stat-label">已完成</text>
        </view>
        <view class="stat-card">
          <text class="stat-number">{{statistics.repair.canceledCount || 0}}</text>
          <text class="stat-label">已取消</text>
        </view>
      </view>
    </view>
    
    <!-- 保养工单统计 -->
    <view class="statistics-area maintenance-stats" bindtap="viewMaintenanceOrders">
      <view class="stat-header">
        <text class="stat-title">保养工单</text>
        <text class="stat-more">查看全部 ></text>
      </view>
      <view class="stat-cards">
        <view class="stat-card">
          <text class="stat-number">{{statistics.maintenance.todoCount || 0}}</text>
          <text class="stat-label">待执行</text>
        </view>
        <view class="stat-card">
          <text class="stat-number">{{statistics.maintenance.processingCount || 0}}</text>
          <text class="stat-label">执行中</text>
    </view>
        <view class="stat-card">
          <text class="stat-number">{{statistics.maintenance.completedCount || 0}}</text>
      <text class="stat-label">已完成</text>
    </view>
        <view class="stat-card">
          <text class="stat-number">{{statistics.maintenance.canceledCount || 0}}</text>
      <text class="stat-label">已取消</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 功能卡片区 -->
  <view class="function-area">
    <view class="section-title">快捷功能</view>
    <view class="function-cards">
      <!-- 动态渲染功能卡片 -->
      <view 
        wx:for="{{functionCards}}" 
        wx:key="id"
        class="function-card"
        style="background-color: {{item.bgColor}};"
        bindtap="navigateTo"
        data-path="{{item.path}}"
      >
        <view class="card-icon">
          <image class="card-image" src="{{item.icon}}" mode="aspectFit"></image>
        </view>
        <view class="card-info">
          <text class="card-title">{{item.title}}</text>
          <text class="card-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 页面底部空白占位，确保内容不被TabBar遮挡 -->
  <view style="height: 100rpx;"></view>
</view> 