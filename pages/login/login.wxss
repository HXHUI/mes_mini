/* pages/login/login.wxss */
.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 100vh;
  background-color: #f8f8f8;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  margin-bottom: 80rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

.login-form {
  width: 85%;
  margin: 0 auto;
}

.input-group {
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.input {
  background-color: #ffffff;
  height: 90rpx;
  border-radius: 8rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  color: #333333;
  border: 1rpx solid #e0e0e0;
}

.login-btn {
  background-color: #0078D7;
  color: #ffffff;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  margin: 60rpx 0 40rpx;
  border-radius: 8rpx;
}

.login-btn:active {
  opacity: 0.8;
}

.other-login {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

.wechat-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #07C160;
  color: #ffffff;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  border-radius: 8rpx;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 10rpx;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.8;
} 