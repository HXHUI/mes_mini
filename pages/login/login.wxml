<!-- pages/login/login.wxml -->
<view class="container">
  <view class="logo-area">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <view class="title">MES生产执行管理系统</view>
  </view>
  
  <view class="login-form">
    <view class="input-group">
      <view class="input-label">用户名</view>
      <input class="input" type="text" placeholder="请输入用户名" bindinput="onUsernameInput" value="{{username}}"/>
    </view>
    
    <view class="input-group">
      <view class="input-label">密码</view>
      <input class="input" password placeholder="请输入密码" bindinput="onPasswordInput" value="{{password}}"/>
    </view>
    
    <button class="login-btn" bindtap="handleLogin" loading="{{isLoading}}" disabled="{{isLoading}}">
      {{isLoading ? '登录中...' : '登 录'}}
    </button>
    
    <view class="other-login">
      <button 
        class="wechat-login-btn" 
        open-type="getPhoneNumber"
        bindgetphonenumber="handleGetPhoneNumber"
        loading="{{isWechatLoading}}"
        disabled="{{isWechatLoading || isLoading}}"
      >
        <image class="wechat-icon" src="/images/icons/wechat.png" mode="aspectFit" wx:if="{{!isWechatLoading}}"></image>
        {{isWechatLoading ? '微信登录中...' : '微信快捷登录'}}
      </button>
    </view>
  </view>
  
  <view class="footer">
    <text>技术支持：MES系统开发团队</text>
    <text>v1.0.0</text>
  </view>
</view> 