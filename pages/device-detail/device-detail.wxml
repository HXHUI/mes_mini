<!-- pages/device-detail/device-detail.wxml -->
<view class="container">
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{isLoading}}">
    <view class="loading-icon"></view>
    <view class="loading-text">加载中...</view>
  </view>

  <view wx:if="{{!isLoading && deviceInfo}}">
    <view class="device-header">
      <view class="device-name">{{deviceInfo.device_name}}</view>
      <view class="device-status {{deviceInfo.status === 'normal' ? 'normal' : 'fault'}}">
        {{deviceInfo.statusText}}
      </view>
    </view>
    
    <view class="device-info">
      <view class="info-item">
        <text class="label">设备编号：</text>
        <text class="value">{{deviceInfo.device_id}}</text>
      </view>
      <view class="info-item">
        <text class="label">设备类型：</text>
        <text class="value">
          <block wx:if="{{deviceInfo.device_type === 'production'}}">生产设备</block>
          <block wx:elif="{{deviceInfo.device_type === 'testing'}}">检测设备</block>
          <block wx:elif="{{deviceInfo.device_type === 'office'}}">办公设备</block>
          <block wx:elif="{{deviceInfo.device_type === 'other'}}">其他设备</block>
          <block wx:else>{{deviceInfo.device_type || '未知'}}</block>
        </text>
      </view>
      <view class="info-item">
        <text class="label">所在位置：</text>
        <text class="value">{{deviceInfo.location || '未知'}}</text>
      </view>
      <view class="info-item">
        <text class="label">所属部门：</text>
        <text class="value">{{deviceInfo.department || '未知'}}</text>
      </view>
      <view class="info-item">
        <text class="label">创建时间：</text>
        <text class="value">{{deviceInfo.created_at || '未知'}}</text>
      </view>
      <view class="info-item" wx:if="{{deviceInfo.description}}">
        <text class="label">设备描述：</text>
        <text class="value">{{deviceInfo.description}}</text>
      </view>
    </view>
    
    <view class="section" wx:if="{{deviceInfo.parameters && deviceInfo.parameters.length > 0}}">
      <view class="section-title">设备参数</view>
      <view class="parameter-list">
        <view class="parameter-item" wx:for="{{deviceInfo.parameters}}" wx:key="name">
          <text class="param-name">{{item.name}}</text>
          <text class="param-value">{{item.value}} {{item.unit}}</text>
        </view>
      </view>
    </view>
    
    <view class="section">
      <view class="section-title">维修记录</view>
      <view class="repair-list">
        <view class="empty-tip" wx:if="{{!repairRecords || repairRecords.length === 0}}">
          暂无维修记录
        </view>
        <view class="repair-item" wx:for="{{repairRecords}}" wx:key="id" bindtap="viewRepairDetail" data-id="{{item.id}}">
          <view class="repair-time">{{item.time}}</view>
          <view class="repair-desc">{{item.description}}</view>
          <view class="repair-person">处理人：{{item.handler}}</view>
        </view>
      </view>
    </view>
    
    <view class="action-bar">
      <button class="action-btn report" bindtap="reportFault">报修</button>
      <button class="action-btn maintenance" bindtap="startMaintenance">维护</button>
    </view>
  </view>
  
  <!-- 无数据提示 -->
  <view class="empty-data" wx:if="{{!isLoading && !deviceInfo}}">
    <image class="empty-icon" src="/images/icons/empty.png" mode="aspectFit"></image>
    <text class="empty-text">未找到设备信息</text>
  </view>
</view> 