/* pages/fault-handle/fault-handle.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
}

/* 选项卡 */
.tabs {
  display: flex;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
  position: sticky;
  top: 0;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
}

.tab {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666666;
  position: relative;
}

.tab.active {
  color: #0078D7;
  font-weight: 500;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background-color: #0078D7;
}

/* 订单列表 */
.order-list {
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.order-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.device-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  flex: 1;
}

.urgency-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.urgency-tag.high {
  background-color: #ffebeb;
  color: #ff4d4f;
}

.urgency-tag.medium {
  background-color: #fff7e6;
  color: #fa8c16;
}

.urgency-tag.low {
  background-color: #e6f7ff;
  color: #1890ff;
}

.order-info {
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.info-item {
  display: flex;
  margin-bottom: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.info-item:last-child {
  margin-bottom: 0;
}

.label {
  width: 150rpx;
  color: #666666;
  font-size: 28rpx;
}

.value {
  flex: 1;
  color: #333333;
  font-size: 28rpx;
  word-break: break-all;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.action-btn {
  margin-left: 20rpx;
  font-size: 28rpx;
  padding: 0 30rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  min-width: 160rpx;
}

.action-btn.view {
  background-color: #ffffff;
  color: #0078D7;
  border: 1rpx solid #0078D7;
}

.action-btn.handle {
  background-color: #0078D7;
  color: #ffffff;
  border: none;
}

.action-btn.complete {
  background-color: #52c41a;
  color: #ffffff;
  border: none;
}

/* 空列表 */
.empty-list {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.loading-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #0078D7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666666;
}

/* 全部加载完成 */
.load-all {
  text-align: center;
  padding: 30rpx 0;
  color: #999999;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
} 