<!-- pages/device-list/device-list.wxml -->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <icon type="search" size="16" color="#999999"></icon>
      <input 
        class="search-input" 
        placeholder="搜索设备名称或编号" 
        value="{{keyword}}"
        confirm-type="search"
        bindinput="onKeywordInput"
        bindconfirm="searchDevices"
      />
      <icon wx:if="{{keyword}}" type="clear" size="16" color="#999999" bindtap="clearKeyword"></icon>
    </view>
  </view>

  <!-- 设备分类选项卡 -->
  <view class="category-tabs">
    <view 
      class="tab {{currentCategoryIndex === -1 ? 'active' : ''}}" 
      bindtap="switchCategory" 
      data-index="-1"
    >
      全部
    </view>
    <view 
      wx:for="{{categories}}" 
      wx:key="value"
      class="tab {{currentCategoryIndex === index ? 'active' : ''}}" 
      bindtap="switchCategory" 
      data-index="{{index}}"
    >
      {{item.text}}
    </view>
  </view>

  <!-- 设备列表 -->
  <view class="device-list">
    <block wx:if="{{deviceList.length > 0}}">
      <view 
        wx:for="{{deviceList}}" 
        wx:key="id" 
        class="device-item"
        bindtap="onDeviceSelect"
        data-device="{{item}}"
      >
        <view class="device-icon">{{item.device_name[0] || '设'}}</view>
        <view class="device-info">
          <view class="device-name">{{item.device_name}}</view>
          <view class="device-id">设备编号：{{item.device_id}}</view>
          <view class="device-location">位置：{{item.location || '未知'}}</view>
        </view>
        <view class="device-status {{item.status === 'active' ? 'normal' : 'fault'}}">
          {{item.status === 'active' ? '正常' : '故障'}}
        </view>
      </view>
    </block>
    
    <view wx:if="{{deviceList.length === 0 && !isLoading}}" class="empty-list">
      <image class="empty-icon" src="/images/icons/empty.png" mode="aspectFit"></image>
      <text class="empty-text">暂无设备数据</text>
    </view>
  </view>
  
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{isLoading}}">
    <view class="loading-icon"></view>
    <view class="loading-text">加载中...</view>
  </view>
  
  <!-- 加载完成提示 -->
  <view class="load-all" wx:if="{{!isLoading && !hasMore && deviceList.length > 0}}">
    已加载全部设备
  </view>
</view> 