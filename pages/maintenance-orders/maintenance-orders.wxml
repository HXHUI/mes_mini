<!-- pages/maintenance-orders/maintenance-orders.wxml -->
<view class="container">
  <view class="fixed-header">
    <view class="filter-bar">
      <view class="search-box">
        <input class="search-input" placeholder="搜索工单号/设备名称/设备编号" bindinput="onSearchInput" value="{{searchText}}" confirm-type="search" bindconfirm="search"/>
        <view class="search-btn" bindtap="search">
          <text class="search-icon">🔍</text>
        </view>
      </view>
      
      <view class="filter-options">
        <checkbox-group bindchange="onAssignedToMeChange">
          <label class="checkbox-label">
            <checkbox value="assigned_to_me" checked="{{assignedToMe}}" />
            <text>分配给我</text>
          </label>
        </checkbox-group>
      </view>
      
      <view class="filter-btn" bindtap="showFilter">
        筛选
        <text class="filter-icon">▼</text>
      </view>
    </view>
    
    <view class="tabs">
      <view class="tab {{tabType === 'all' ? 'active' : ''}}" bindtap="switchTab" data-type="all">
        全部
      </view>
      <view class="tab {{tabType === 'unassigned' ? 'active' : ''}}" bindtap="switchTab" data-type="unassigned">
        待分配
      </view>
      <view class="tab {{tabType === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-type="pending">
        待执行
      </view>
      <view class="tab {{tabType === 'processing' ? 'active' : ''}}" bindtap="switchTab" data-type="processing">
        进行中
      </view>
      <view class="tab {{tabType === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-type="completed">
        已完成
      </view>
      <view class="tab {{tabType === 'accepted' ? 'active' : ''}}" bindtap="switchTab" data-type="accepted">
        已验收
      </view>
      <view class="tab {{tabType === 'cancelled' ? 'active' : ''}}" bindtap="switchTab" data-type="cancelled">
        已取消
      </view>
    </view>
  </view>
  
  <view class="order-list">
    <block wx:if="{{orderList.length > 0}}">
      <view 
        wx:for="{{orderList}}" 
        wx:key="id" 
        class="order-item"
        bindtap="viewOrderDetail"
        data-id="{{item.id}}"
      >
        <view class="order-header">
          <view class="order-id">工单号：{{item.id}}</view>
          <view class="order-status {{item.status}}">
            {{item.status === 'unassigned' ? '待分配' :
              (item.status === 'pending' ? '待执行' : 
                (item.status === 'in_progress' ? (item.hasStarted ? '进行中' : '待开始') : 
                  (item.status === 'completed' ? '已完成' : 
                    (item.status === 'accepted' ? '已验收' :
                      (item.status === 'cancelled' ? '已取消' : '未知状态')))))}}
          </view>
        </view>
        
        <view class="order-content">
          <view class="device-info">
            <view class="device-name">{{item.device_name || '未知设备'}}</view>
            <view class="device-id">设备编号：{{item.device_id || '未知'}}</view>
          </view>
          
          <view class="maintenance-type">
            <text class="label">保养类型：</text>
            <text class="value">{{
              item.maintenance_type === 'routine' ? '日常保养' : 
              item.maintenance_type === 'periodic' ? '定期保养' : 
              item.maintenance_type === 'preventive' ? '预防性保养' : 
              item.maintenance_type === 'corrective' ? '纠正性保养' : 
              item.plan_id ? '计划保养' :
              '未分类'
            }}</text>
          </view>
          
          <view class="maintenance-desc">
            <text class="label">保养内容：</text>
            <text class="value">{{item.description || '无描述'}}</text>
          </view>
          
          <view class="time-info">
            <view class="schedule-time">
              <text class="label">计划时间：</text>
              <text class="value">{{item.scheduled_start ? (item.scheduled_start + ' ~ ' + (item.scheduled_end || '未设置')) : (item.scheduled_at || item.created_at || '--')}}</text>
            </view>
            
            <view class="assign-info">
              <text class="label">承接/分配时间：</text>
              <text class="value">{{item.assigned_at || item.updated_at || '--'}}</text>
            </view>
            
            <view class="actual-start" wx:if="{{item.hasStarted}}">
              <text class="label">实际开始时间：</text>
              <text class="value">{{item.actual_start || '--'}}</text>
            </view>
            
            <view class="person-info">
            <view class="planner">
              <text class="label">计划人：</text>
              <text class="value">{{item.creator_name || '未知'}}</text>
              </view>
              
              <view class="handler">
                <text class="label">负责人：</text>
                <text class="value">{{item.assigned_to_name || item.handler_name || '未分配'}}</text>
              </view>
            </view>
          </view>
        </view>
        
        <view class="order-footer">
          <view class="priority-tag {{item.priority_level}}">
            {{item.priority_level === 'high' ? '高' : 
              item.priority_level === 'urgent' ? '紧急' :
              item.priority_level === 'medium' ? '中' : 
              item.priority_level === 'low' ? '低' : '普通'}}
          </view>
          
          <view class="btn-group">
            <button 
              class="action-btn {{(item.status === 'pending' || item.status === 'unassigned') && !item.assigned_to_name && !item.handler_name ? 'handle' : 'view'}}" 
              catchtap="{{(item.status === 'pending' || item.status === 'unassigned') && !item.assigned_to_name && !item.handler_name ? 'handleOrder' : 'viewDetail'}}"
              data-id="{{item.id}}"
            >
              {{(item.status === 'pending' || item.status === 'unassigned') && !item.assigned_to_name && !item.handler_name ? '接单处理' : '查看详情'}}
            </button>
          </view>
        </view>
      </view>
    </block>
    
    <view wx:if="{{orderList.length === 0 && !loading}}" class="empty-list">
      <image class="empty-icon" src="/images/icons/empty.png" mode="aspectFit"></image>
      <text class="empty-text">暂无保养工单</text>
    </view>
  </view>
  
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-icon"></view>
    <view class="loading-text">加载中...</view>
  </view>
  
  <view class="load-all" wx:if="{{!loading && !hasMore && orderList.length > 0}}">
    已加载全部工单
  </view>
</view> 