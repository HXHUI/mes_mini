<!-- pages/fault-handle/fault-handle.wxml -->
<view class="container">
  <view class="tabs">
    <view class="tab {{active === 0 ? 'active' : ''}}" bindtap="handleTabChange" data-index="0">
      待处理
    </view>
    <view class="tab {{active === 1 ? 'active' : ''}}" bindtap="handleTabChange" data-index="1">
      处理中
    </view>
  </view>
  
  <view class="tab-content">
    <!-- 待处理工单列表 -->
    <view class="order-list" wx:if="{{active === 0}}">
      <block wx:if="{{pendingList.length > 0}}">
        <view 
          wx:for="{{pendingList}}" 
          wx:key="id" 
          class="order-item urgency-{{item.urgency_level}}"
        >
          <view class="order-header">
            <view class="device-name">{{item.device_name || '未知设备'}}</view>
            <view class="urgency-tag {{item.urgency_level}}">
              {{item.urgency_level === 'high' || item.urgency_level === 'urgent' ? '紧急' : 
                (item.urgency_level === 'medium' ? '一般' : '普通')}}
            </view>
          </view>
          
          <view class="order-info">
            <view class="info-item">
              <text class="label">设备编号:</text>
              <text class="value">{{item.device_id || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="label">故障描述:</text>
              <text class="value">{{item.description || '无描述'}}</text>
            </view>
            <view class="info-item">
              <text class="label">报修时间:</text>
              <text class="value">{{item.created_at || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="label">报修人:</text>
              <text class="value">{{item.creator_name || '未知'}}</text>
            </view>
            <view class="info-item" wx:if="{{item.fault_type}}">
              <text class="label">故障类型:</text>
              <text class="value">{{item.fault_type === 'mechanical' ? '机械故障' : 
                (item.fault_type === 'electrical' ? '电气故障' : 
                (item.fault_type === 'software' ? '软件故障' : '其他故障'))}}</text>
            </view>
          </view>
          
          <view class="order-actions">
            <button class="action-btn view" bindtap="viewDetail" data-id="{{item.id}}">查看详情</button>
            <button class="action-btn handle" bindtap="handleOrder" data-id="{{item.id}}" data-index="{{index}}">接单处理</button>
          </view>
        </view>
      </block>
      
      <view wx:if="{{pendingList.length === 0 && !loading}}" class="empty-list">
        <image class="empty-icon" src="/images/icons/empty.png" mode="aspectFit"></image>
        <text class="empty-text">暂无待处理工单</text>
      </view>
    </view>
    
    <!-- 处理中工单列表 -->
    <view class="order-list" wx:if="{{active === 1}}">
      <block wx:if="{{processingList.length > 0}}">
        <view 
          wx:for="{{processingList}}" 
          wx:key="id" 
          class="order-item urgency-{{item.urgency_level}}"
        >
          <view class="order-header">
            <view class="device-name">{{item.device_name || '未知设备'}}</view>
            <view class="urgency-tag {{item.urgency_level}}">
              {{item.urgency_level === 'high' || item.urgency_level === 'urgent' ? '紧急' : 
                (item.urgency_level === 'medium' ? '一般' : '普通')}}
            </view>
          </view>
          
          <view class="order-info">
            <view class="info-item">
              <text class="label">设备编号:</text>
              <text class="value">{{item.device_id || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="label">故障描述:</text>
              <text class="value">{{item.description || '无描述'}}</text>
            </view>
            <view class="info-item">
              <text class="label">报修时间:</text>
              <text class="value">{{item.created_at || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="label">报修人:</text>
              <text class="value">{{item.creator_name || '未知'}}</text>
            </view>
            <view class="info-item" wx:if="{{item.fault_type}}">
              <text class="label">故障类型:</text>
              <text class="value">{{item.fault_type === 'mechanical' ? '机械故障' : 
                (item.fault_type === 'electrical' ? '电气故障' : 
                (item.fault_type === 'software' ? '软件故障' : '其他故障'))}}</text>
            </view>
          </view>
          
          <view class="order-actions">
            <button class="action-btn view" bindtap="viewDetail" data-id="{{item.id}}">查看详情</button>
            <button class="action-btn complete" bindtap="completeOrder" data-id="{{item.id}}" data-index="{{index}}">完成工单</button>
          </view>
        </view>
      </block>
      
      <view wx:if="{{processingList.length === 0 && !loading}}" class="empty-list">
        <image class="empty-icon" src="/images/icons/empty.png" mode="aspectFit"></image>
        <text class="empty-text">暂无处理中工单</text>
      </view>
    </view>
  </view>
  
  <!-- 显示当前工单数量信息 -->
  <view class="order-count" wx:if="{{(active === 0 && pendingList.length > 0) || (active === 1 && processingList.length > 0)}}">
    当前显示: {{active === 0 ? pendingList.length : processingList.length}} 条记录
  </view>
  
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-icon"></view>
    <view class="loading-text">加载中...</view>
  </view>
  
  <view class="load-all" wx:if="{{!loading && ((active === 0 && !pendingHasMore && pendingList.length > 0) || (active === 1 && !processingHasMore && processingList.length > 0))}}">
    已加载全部工单
  </view>
</view> 