/* pages/account-bind/account-bind.wxss */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  box-sizing: border-box;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
  margin-bottom: 80rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
}

.bind-form {
  width: 100%;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  background-color: #F5F7FA;
  border-radius: 8rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.bind-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #0078D7;
  color: #fff;
  font-size: 30rpx;
  border-radius: 8rpx;
  margin-top: 50rpx;
}

.tips {
  text-align: center;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.actions {
  margin-top: 80rpx;
  width: 100%;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #fff;
  color: #0078D7;
  font-size: 30rpx;
  border: 1px solid #0078D7;
  border-radius: 8rpx;
} 