/* pages/scan/scan.wxss */
.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #000000;
}

/* 权限被拒绝时的提示样式 */
.permission-denied {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx;
  background-color: #ffffff;
}

.permission-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 40rpx;
}

.permission-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  text-align: center;
}

.permission-desc {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.5;
}

.permission-btn {
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #0078D7;
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
}

.permission-btn.secondary {
  background-color: #f5f5f5;
  color: #333333;
}

.scan-area {
  position: relative;
  width: 100%;
  height: 750rpx;
}

.camera {
  width: 100%;
  height: 100%;
}

.scan-frame {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 500rpx;
  height: 500rpx;
  transform: translate(-50%, -50%);
  border: 6rpx solid #0078D7;
  border-radius: 20rpx;
  overflow: hidden;
}

.scan-line {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 4rpx;
  background-color: #0078D7;
  animation: scan 2s linear infinite;
}

@keyframes scan {
  0% {
    top: 0;
  }
  50% {
    top: 100%;
  }
  100% {
    top: 0;
  }
}

.tips {
  position: absolute;
  bottom: 30rpx;
  left: 0;
  width: 100%;
  text-align: center;
}

.tip-text {
  color: #ffffff;
  font-size: 28rpx;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  display: inline-block;
}

.scan-controls {
  display: flex;
  justify-content: space-around;
  width: 100%;
  padding: 40rpx 0;
  background-color: #ffffff;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 10rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #333333;
}

.scan-history {
  width: 100%;
  padding: 30rpx;
  background-color: #ffffff;
}

.history-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.history-list {
  margin-top: 10rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-name {
  font-size: 28rpx;
  color: #333333;
}

.history-time {
  font-size: 24rpx;
  color: #999999;
} 