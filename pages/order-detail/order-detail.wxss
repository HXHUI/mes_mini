/* pages/order-detail/order-detail.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #ffffff;
  margin: 0 10rpx 10rpx 10rpx;
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.order-id {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

/* 工单状态标签样式 */
.status-tag {
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  text-align: center;
  min-width: 120rpx;
}

.status-tag.pending {
  background-color: #fa8c16;
}

.status-tag.in_progress, .status-tag.processing {
  background-color: #1890ff;
}

.status-tag.completed {
  background-color: #52c41a;
}

.order-status {
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-left: 20rpx;
  font-weight: normal;
}

.order-status.pending {
  background-color: #fff7e6;
  color: #fa8c16;
}

.order-status.processing {
  background-color: #e6f7ff;
  color: #1890ff;
}

.order-status.completed {
  background-color: #f6ffed;
  color: #52c41a;
}

.order-section {
  background-color: #ffffff;
  padding: 20rpx;
  margin: 0 10rpx 10rpx 10rpx;
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 添加标题行样式，用于容纳标题和按钮 */
.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title-row .section-title {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

/* 开始任务按钮样式 */
.start-task-btn {
  font-size: 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #1890ff;
  color: #ffffff;
  padding: 0 30rpx;
  border-radius: 30rpx;
  margin: 0;
}

.start-task-btn.disabled {
  background-color: #d9d9d9;
  color: #ffffff;
}

.info-item {
  display: flex;
  padding: 15rpx 0;
  font-size: 30rpx;
  line-height: 1.6;
}

.info-item.description {
  display: block;
}

.info-item.description .label {
  display: block;
  margin-bottom: 10rpx;
}

.info-item.description .value {
  display: block;
  word-break: break-all;
  white-space: pre-wrap;
}

.label {
  width: 160rpx;
  color: #666666;
  font-size: 30rpx;
}

.value {
  flex: 1;
  color: #333333;
  font-size: 30rpx;
}

.value.urgency {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.value.urgency.high, .value.urgency.urgent {
  background-color: #ffebeb;
  color: #ff4d4f;
}

.value.urgency.medium {
  background-color: #fff7e6;
  color: #fa8c16;
}

.value.urgency.low {
  background-color: #e6f7ff;
  color: #1890ff;
}

/* 优先级行样式 */
.priority-row {
  display: flex;
  align-items: center;
}

/* 优先级标签样式 */
.priority {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  padding: 0 12rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 20rpx;
  text-align: center;
  min-width: 40rpx;
  box-sizing: border-box;
  font-weight: normal;
  white-space: nowrap;
  margin-left: 10rpx;
}

.priority.high {
  background-color: #ffebeb;
  color: #ff4d4f;
}

.priority.medium {
  background-color: #fff7e6;
  color: #fa8c16;
}

.priority.low {
  background-color: #e6f7ff;
  color: #1890ff;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.fault-image {
  width: 220rpx;
  height: 220rpx;
  margin: 10rpx;
  background-color: #f0f0f0;
}

.action-bar {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
  background-color: #ffffff;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  background-color: #3a80dd;
  color: #ffffff;
  border: none;
}

.action-btn.handle {
  background-color: #3a80dd;
  color: #ffffff;
  border: none;
}

.action-btn.complete {
  background-color: #52c41a;
  color: #ffffff;
  border: none;
}

.action-btn.view {
  background-color: #ffffff;
  color: #3a80dd;
  border: 1rpx solid #3a80dd;
}

/* 加载状态样式 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300px;
}

.loading {
  color: #999;
  font-size: 16px;
}

/* 任务列表样式 */
.task-list {
  margin-top: 10rpx;
}

.task-item {
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  background-color: #fff;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed #eee;
}

.task-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
  /* 处理名称过长时的省略显示 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.task-info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 5px;
}

.info-label {
  color: #666;
  min-width: 80px;
}

.time-value {
  color: #333;
  font-weight: 500;
}

/* 任务状态样式优化 */
.task-status {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 12px;
  color: #fff;
  background-color: #ccc;
  margin-left: 10px;
}

.task-status.pending {
  background-color: #ff9800;
}

.task-status.in_progress {
  background-color: #2196F3;
}

.task-status.completed {
  background-color: #4CAF50;
}

.task-status.skipped {
  background-color: #9E9E9E;
}

.task-info {
  display: flex;
  margin-top: 10rpx;
  font-size: 28rpx;
}

.task-info .label {
  width: 160rpx;
  color: #666;
}

.task-info .value {
  flex: 1;
  color: #333;
}

/* 任务操作按钮样式 */
.task-action {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.task-btn {
  padding: 4rpx 16rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  background-color: #1890ff;
  color: #fff;
  line-height: 1.8;
  min-height: auto;
  width: auto;
}

.task-btn.skip {
  background-color: #f5f5f5;
  color: #666;
  margin-left: 16rpx;
}

/* 任务实际耗时输入样式 */
.task-actual-time {
  margin-top: 14rpx;
  margin-bottom: 14rpx;
  border-top: 1rpx solid #eee;
  padding-top: 14rpx;
}

.input-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.input-group {
  display: flex;
  align-items: center;
}

.time-input {
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 6rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  background-color: #fff;
  width: 100%;
  box-sizing: border-box;
}

.task-btn.disabled {
  background-color: #cccccc;
  color: #999999;
  opacity: 0.6;
}

.task-info-container {
  padding: 0 0 4rpx 0;
}

/* 紧急程度标签样式 */
.urgency-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.urgency-tag.high, .urgency-tag.urgent {
  background-color: #ff4d4f;
}

.urgency-tag.medium {
  background-color: #fa8c16;
}

.urgency-tag.low {
  background-color: #1890ff;
} 